# Dev Port Manager - Environment Configuration
# Copy this file to .env and customize as needed

# Web Dashboard Port
PORT=4000

# Custom Registry Path (optional)
# Leave empty to use default (~/.dev-ports/registry.json)
# DEVPORT_REGISTRY=/path/to/custom/registry.json

# Node Environment
NODE_ENV=development

# Enable verbose logging
# DEBUG=true

# Disable auto-update (for desktop app)
# DISABLE_AUTO_UPDATE=true
