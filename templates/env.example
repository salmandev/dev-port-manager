# Dev Port Manager - Environment Configuration
# Generated automatically when assigning a project
#
# This file is used by Docker Compose to configure port mappings
# Do not commit this file to version control if it contains sensitive data

# Project Configuration
PROJECT_NAME=my-project
PROJECT_TYPE=node

# Network Configuration
# PORT: The host port assigned by Dev Port Manager
# This port is mapped to the container's internal port (usually 8080)
PORT=9000

# HOST: The localtest.me hostname for this project
HOST=my-project.localtest.me

# URL: Full access URL for the project
URL=http://my-project.localtest.me:9000

# Docker Configuration
# CONTAINER_PORT: Internal port the application runs on inside the container
CONTAINER_PORT=8080

# Additional environment variables for your application
NODE_ENV=development
DEBUG=true
